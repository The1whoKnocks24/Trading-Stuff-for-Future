// --- Add minutes to session END ---
f_extendSession(_ses, _addMin) =>
    parts     = str.split(_ses, "-")
    startStr  = array.get(parts, 0)
    endStr    = array.get(parts, 1)

    endHour   = str.tonumber(str.substring(endStr, 0, 2))
    endMin    = str.tonumber(str.substring(endStr, 2, 4))

    totalMin  = endHour * 60 + endMin + _addMin
    newHour   = math.floor(totalMin / 60) % 24
    newMin    = totalMin % 60

    endNewStr = str.format("{0,number,00}{1,number,00}", newHour, newMin)
    startStr + "-" + endNewStr

