// Simple string repeater (works everywhere)
repeat_str(string s, int count) =>
    string out = ""
    for i = 0 to count - 1
        out += s
    out

get_range(session, session_name, session_css) =>
    // === BOX TEXT POSITION (optional padding) ===
    // xPad = spaces before text (pushes text right)
    // yPad = newlines before text (pushes text down)
    int xPad = -4
    int yPad = 0

    var float max = high
    var float min = low
    var box   bx  = na

    if session > session[1]
        max := high
        min := low

        // One-line box.new to avoid line-continuation issues
        bx := box.new(bar_index, max, bar_index, min,
             bgcolor=color.new(session_css, bg_transp),
             border_color=show_outline ? session_css : na,
             border_style=line.style_dotted)

        // Session "label" uses BOX TEXT (not label objects)
        if show_txt
            string padX = xPad > 0 ? repeat_str(" ",  xPad) : ""
            string padY = yPad > 0 ? repeat_str("\n", yPad) : ""
            box.set_text(bx, padY + padX + session_name)
            box.set_text_color(bx, session_css)
            box.set_text_size(bx, size.normal)
            box.set_text_halign(bx, text.align_left)
            box.set_text_valign(bx, text.align_top)

    if session and session == session[1]
        max := math.max(high, max)
        min := math.min(low, min)
        box.set_top(bx, max)
        box.set_rightbottom(bx, bar_index, min)

        // keep text updated (optional)
        if show_txt and not na(bx)
            string padX = xPad > 0 ? repeat_str(" ",  xPad) : ""
            string padY = yPad > 0 ? repeat_str("\n", yPad) : ""
            box.set_text(bx, padY + padX + session_name)

    [session ? na : max, session ? na : min]

